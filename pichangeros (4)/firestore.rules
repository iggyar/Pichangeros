rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "iggy666thepro@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    function isFieldOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }

    // Users
    match /users/{userId} {
      function isValidUser() {
        let data = request.resource.data;
        return data.keys().hasAll(['uid', 'role', 'createdAt']) &&
               data.uid == userId &&
               data.role in ['user', 'owner', 'admin'];
      }
      
      allow read: if isAuthenticated(); // Allow reading profile to check role
      allow create: if isAuthenticated() && 
                       isOwner(userId) && 
                       isValidUser() && 
                       (request.resource.data.role in ['user', 'owner'] || isAdmin());
      allow update: if isAuthenticated() && 
                       (
                         (isOwner(userId) && 
                          request.resource.data.role == resource.data.role && 
                          request.resource.data.uid == resource.data.uid) || 
                         isAdmin()
                       );
    }

    // Fields
    match /fields/{fieldId} {
      function isValidField() {
        let data = request.resource.data;
        return data.keys().hasAll(['name', 'pricePerHour', 'location', 'ownerId', 'status']) &&
               data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
               data.pricePerHour is number && data.pricePerHour >= 0 &&
               (data.ownerId == request.auth.uid || isAdmin()) &&
               data.status in ['approved', 'pending', 'rejected', 'inactive'];
      }

      allow read: if true; // Public access for search, specific logic in list
      allow create: if isAuthenticated() && isValidField();
      allow update: if isAuthenticated() && (isFieldOwner(resource.data.ownerId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Bookings
    match /bookings/{bookingId} {
      function isValidBooking() {
        let data = request.resource.data;
        return data.keys().hasAll(['userId', 'fieldId', 'ownerId', 'date', 'timeSlot', 'price', 'securityCode', 'status']) &&
               data.userId is string &&
               data.fieldId is string &&
               data.ownerId is string &&
               data.status in ['active', 'completed', 'cancelled'];
      }

      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.ownerId || isAdmin());
      allow create: if isAuthenticated() && 
                       isValidBooking() && 
                       request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.ownerId || isAdmin());
    }

    // Reviews
    match /reviews/{reviewId} {
      function isValidReview() {
        let data = request.resource.data;
        return data.keys().hasAll(['fieldId', 'userId', 'rating', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.rating >= 1 && data.rating <= 5;
      }
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview();
      allow update: if (isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid));
    }

    // Payment Methods
    match /paymentMethods/{pmId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.reporterId == request.auth.uid;
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      
      match /messages/{msgId} {
        allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.senderId && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
